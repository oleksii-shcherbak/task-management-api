# Application
APP_NAME="Task Management API"
DEBUG=true

# Database - direct connection (used when running locally without Docker)
DATABASE_URL=postgresql+asyncpg://localhost:5432/taskapi_db

# Security
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Docker Compose - PostgreSQL service credentials
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=taskapi
POSTGRES_DB=taskapi_db

# Redis
REDIS_URL=redis://localhost:6379
