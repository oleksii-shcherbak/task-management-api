# Application
APP_NAME="Task Management API"
DEBUG=true

# Database - direct connection (used when running locally without Docker)
DATABASE_URL=postgresql+asyncpg://localhost:5432/taskapi_db

# Security
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Docker Compose - PostgreSQL service credentials
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=taskapi
POSTGRES_DB=taskapi_db

# Redis
REDIS_URL=redis://localhost:6379

# File storage
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# Email (SMTP) - leave SMTP_HOST empty to log emails instead of sending them
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@taskapi.dev

# Base URL used in email links - set to your frontend URL in production
FRONTEND_URL=http://localhost:8000

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
